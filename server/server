#!/usr/bin/env bash
# Wrapper for the Zappy server (S01).
# Invoked as ./server/server (root ./server is the directory on Unix).
# Builds the Rust binary if needed, then execs it with all CLI args.
# Real argument parsing lives in src/cli.rs; usage/exit behavior comes from there.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN="${ROOT}/target/release/zappy-server"

# Build quietly. cargo progress goes to stderr, so the binary's own stdout
# (usage text, config echo) stays clean for auditors and tests.
if ! cargo build --release --quiet --manifest-path "${ROOT}/Cargo.toml" 1>&2; then
  echo "error: failed to build zappy-server" >&2
  exit 1
fi

exec "${BIN}" "$@"
